LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=z-ai/glm-5.2

# Optional per-role overrides. The maker uses LLM_MODEL_MAKER (or LLM_MODEL).
# Level 3's checker and reviewer use these; unset roles fall back to LLM_MODEL.
LLM_MODEL_MAKER=z-ai/glm-5.2
LLM_MODEL_CHECKER=deepseek/deepseek-v4-flash
LLM_MODEL_REVIEWER=moonshotai/kimi-k2-thinking
